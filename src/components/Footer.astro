---
---
<footer id="footer" class="relative pt-16 sm:pt-20 pb-10 px-6 sm:px-10 lg:px-14 overflow-hidden" style="background: var(--black);">

  <!-- Top divider -->
  <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(201,169,110,0.2), transparent);"></div>

  <div class="max-w-7xl mx-auto">

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-6 pb-10 mb-10 border-b" style="border-color: rgba(201,169,110,0.1);">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <span class="font-display font-light text-2xl tracking-[0.2em] mb-5 block" style="color: var(--cream);">
          CY<span class="italic" style="color: var(--gold);">.</span>LOR
        </span>
        <p class="font-mono text-[0.58rem] tracking-[0.15em] leading-relaxed uppercase" style="color: var(--muted);">
          Software para condomínios<br/>
          com foco em rotina e facilidade.<br/>
          Atendimento para síndicos,<br/>
          administradoras e portarias.
        </p>
      </div>

      <!-- Produto -->
      <div>
        <p class="font-mono text-[0.58rem] tracking-[0.28em] uppercase mb-5" style="color: var(--gold);">Produto</p>
        <nav class="flex flex-col gap-3">
          {[
            { label: 'Como funciona', href: '#lifestyle' },
            { label: 'Facilidades',   href: '#expertise' },
            { label: 'Resultados',    href: '#cases' },
            { label: 'Agendar demo',  href: '#contact' },
          ].map(link => (
            <a href={link.href} class="font-body text-sm transition-colors duration-300 hover:text-cyllor-gold" style="color: rgba(240,235,225,0.5);">
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Legal -->
      <div>
        <p class="font-mono text-[0.58rem] tracking-[0.28em] uppercase mb-5" style="color: var(--gold);">Legal</p>
        <nav class="flex flex-col gap-3">
          {[
            { label: 'Política de Privacidade', href: '/politica-de-privacidade' },
            { label: 'Termos de Uso',           href: '/termos-de-uso' },
            { label: 'Compliance',              href: '/compliance' },
          ].map(link => (
            <a href={link.href} class="font-body text-sm transition-colors duration-300 hover:text-cyllor-gold" style="color: rgba(240,235,225,0.5);">
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Contact -->
      <div>
        <p class="font-mono text-[0.58rem] tracking-[0.28em] uppercase mb-5" style="color: var(--gold);">Contato</p>
        <div class="flex flex-col gap-3">
          <a href="mailto:contato@cyllor.com" class="font-body text-sm transition-colors duration-300 hover:text-cyllor-gold" style="color: rgba(240,235,225,0.5);">
            contato@cyllor.com
          </a>
          <a href="#contact" class="btn-gold text-center mt-2">
            Agendar demo
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="font-mono text-[0.55rem] tracking-widest uppercase" style="color: rgba(240,235,225,0.2);">
        © {new Date().getFullYear()} Cyllor. Software para condomínios.
      </p>
      <!-- Gold line -->
      <div class="h-px w-16 sm:w-24" style="background: rgba(201,169,110,0.3);"></div>
    </div>
  </div>
</footer>
