---
const steps = [
  {
    number: '01',
    title: 'Discovery & Assessment',
    desc: 'Mapeamos toda a sua infraestrutura atual, identificamos gargalos, débito técnico e oportunidades de crescimento.',
    tech: 'Architecture Review Board · Well-Architected Framework',
  },
  {
    number: '02',
    title: 'Design de Solução',
    desc: 'Elaboramos o blueprint técnico detalhado: componentes, fluxos de dados, APIs, integrações e plano de migração.',
    tech: 'C4 Model · ADRs · Domain Storytelling',
  },
  {
    number: '03',
    title: 'Implementação Iterativa',
    desc: 'Entrega em sprints de alta cadência com pair programming, code reviews rigorosos e automação de testes.',
    tech: 'TDD · BDD · CI/CD Pipelines',
  },
  {
    number: '04',
    title: 'Observabilidade Contínua',
    desc: 'Monitoramento full-stack desde o lançamento. SLIs, SLOs e alertas proativos para garantir SLAs de 99.9%.',
    tech: 'OpenTelemetry · Grafana Stack · PagerDuty',
  },
  {
    number: '05',
    title: 'Escala & Otimização',
    desc: 'Tuning contínuo de performance, otimização de custos cloud e expansão da arquitetura conforme a demanda cresce.',
    tech: 'FinOps · Chaos Engineering · Load Testing',
  },
];
---

<div id="architecture">
<!-- MOBILE: vertical scroll list -->
<section class="relative py-20 sm:py-28 px-5 sm:px-8 lg:hidden">
  <div class="absolute top-0 left-8 right-8 h-px bg-gradient-to-r from-transparent via-cyllor-border to-transparent" />

  <div class="max-w-2xl mx-auto">
    <p class="section-label mb-5">02 / Arquitetura de Soluções</p>
    <h2 class="font-display font-bold text-section text-white leading-tight mb-14">
      Do problema à<span class="text-gradient"> produção.</span>
    </h2>

    <div class="relative">
      <!-- Vertical connector line -->
      <div class="absolute left-7 top-0 bottom-0 w-px bg-gradient-to-b from-cyllor-cyan via-cyllor-border to-transparent opacity-40" />

      <div class="space-y-6 pl-2">
        {steps.map((step, i) => (
          <div class="arch-step-mobile relative flex gap-5 items-start">
            <!-- Number badge -->
            <div class="flex-shrink-0 w-14 h-14 flex items-center justify-center border border-cyllor-border bg-cyllor-surface z-10">
              <span class="font-mono text-lg font-bold text-cyllor-cyan">{step.number}</span>
            </div>

            <!-- Content -->
            <div class="flex-1 pb-6">
              <h3 class="font-display font-semibold text-white text-lg mb-2">{step.title}</h3>
              <p class="font-body text-sm text-cyllor-silver-dim leading-relaxed mb-2">{step.desc}</p>
              <p class="font-mono text-xs text-cyllor-muted">{step.tech}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- DESKTOP: horizontal pinned scroll -->
<section
  id="architecture-desktop"
  class="relative overflow-hidden hidden lg:block"
  style="height: 100vh;"
>
  <div class="absolute top-0 left-16 right-16 h-px bg-gradient-to-r from-transparent via-cyllor-border to-transparent z-10" />

  <!-- Section header -->
  <div class="absolute top-24 left-16 z-10">
    <p class="section-label mb-4">02 / Arquitetura de Soluções</p>
    <h2 class="font-display font-bold text-section text-white leading-tight max-w-sm">
      Do problema à<span class="text-gradient"> produção.</span>
    </h2>
  </div>

  <!-- Scrollable track -->
  <div
    id="arch-track"
    class="flex items-end gap-0 h-full will-change-transform"
    style="width: max-content; padding-top: 15rem; padding-bottom: 6rem;"
  >
    <div class="flex-shrink-0" style="width: calc(16vw + 2rem)"></div>

    {steps.map((step, i) => (
      <article class="arch-step flex-shrink-0 relative w-[420px] mr-6" data-cursor-hover>
        {i < steps.length - 1 && (
          <div class="absolute top-1/2 -right-6 w-6 h-px bg-cyllor-cyan opacity-30" />
        )}
        <div class="p-10 border border-cyllor-border bg-cyllor-surface hover:border-cyllor-cyan transition-all duration-500 group h-80 flex flex-col justify-between"
          style="background: linear-gradient(135deg, #0e0e0e 0%, #080808 100%)"
        >
          <span class="font-mono text-7xl font-bold text-cyllor-border group-hover:text-cyllor-cyan-glow transition-colors duration-500 select-none leading-none">
            {step.number}
          </span>
          <div>
            <h3 class="font-display font-semibold text-white text-xl mb-3 group-hover:text-cyllor-cyan transition-colors duration-300">{step.title}</h3>
            <p class="font-body text-sm text-cyllor-silver-dim leading-relaxed mb-4">{step.desc}</p>
            <p class="font-mono text-xs text-cyllor-muted">{step.tech}</p>
          </div>
        </div>
      </article>
    ))}

    <div class="flex-shrink-0 w-32" />
  </div>

  <div class="absolute bottom-8 right-8 z-10 flex items-center gap-3">
    <span class="font-mono text-xs text-cyllor-muted tracking-widest">ARRASTE</span>
    <svg width="24" height="12" viewBox="0 0 24 12" fill="none">
      <path d="M2 6h20M16 2l6 4-6 4" stroke="#3a3a4a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</section>
</div>

