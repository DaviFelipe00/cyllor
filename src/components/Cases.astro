---
// Cases: "Resultados" — Updated to be a clean, framed grid
const cases = [
  {
    num: '01',
    client: 'Comunicação Unificada',
    category: 'Comunicação',
    result: 'Centralização de avisos e reservas das áreas comuns em um fluxo mais simples.',
    metrics: [
      { value: '72%', label: 'Menos ruído' },
      { value: '1', label: 'Canal' },
      { value: '24h', label: 'Respostas' },
    ],
    img: 'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?w=1200&q=80&auto=format&fit=crop',
  },
  {
    num: '02',
    client: 'Uso Inteligente de Espaços',
    category: 'Reservas',
    result: 'Organização da agenda de salão, churrasqueira e quadra com menos conflitos.',
    metrics: [
      { value: '60%', label: 'Conflitos' },
      { value: '3×', label: 'Adesão' },
      { value: '0', label: 'Planilhas' },
    ],
    img: 'https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=1200&q=80&auto=format&fit=crop',
  },
  {
    num: '03',
    client: 'Controle de Acesso Ágil',
    category: 'Acesso',
    result: 'Fluxo de autorização mais claro para moradores, recepção ágil na entrada.',
    metrics: [
      { value: '45%', label: 'Espera' },
      { value: '100%', label: 'Controle' },
      { value: '1', label: 'Fluxo' },
    ],
    img: 'https://images.unsplash.com/photo-1486325212027-8081e485255e?w=1200&q=80&auto=format&fit=crop',
  },
];
---
<section id="cases" class="relative py-24 sm:py-32 overflow-hidden" style="background: var(--bg-alt);">

  <div class="section-divider"></div>

  <!-- Perfectly framed container -->
  <div class="px-6 sm:px-10 lg:px-14 max-w-7xl mx-auto">
    
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12 sm:mb-16">
      <div data-reveal>
        <div class="flex items-center gap-4 mb-4 lg:mb-6">
          <div class="w-8 h-px bg-blue-500/30"></div>
          <p class="font-mono text-[0.55rem] sm:text-[0.6rem] tracking-[0.28em] uppercase text-blue-500">Resultados</p>
        </div>
        <h2 class="font-display font-light leading-tight tracking-tighter" style="font-size: clamp(2.2rem, 5vw, 4.5rem); color: var(--text);">
          Cenários reais,<br/>
          <span class="font-bold" style="color: var(--blue);">ganhos concretos.</span>
        </h2>
      </div>
    </div>

    <!-- 3-Column Standard Grid Layout to ensure perfect framing -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {cases.map((c, i) => (
        <article
          class="flex flex-col border rounded-lg overflow-hidden group shadow-sm hover:shadow-lg transition-all duration-300 bg-white"
          style="border-color: rgba(15,23,42,0.06);"
          data-reveal
          data-delay={i * 100}
          data-cursor-hover
        >
          <!-- Photo Container -->
          <div class="aspect-[16/10] relative overflow-hidden">
            <img
              src={c.img}
              alt={c.client}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <!-- Dark gradient over photo for white text readability -->
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.85) 0%, rgba(15,23,42,0.2) 60%, transparent 100%);"></div>
            
            <!-- Floating Category Tag & Title -->
            <div class="absolute bottom-0 left-0 right-0 p-5 lg:p-6">
              <span class="inline-block font-mono text-[0.55rem] tracking-[0.2em] uppercase px-2.5 py-1 rounded-full mb-3 shadow-sm bg-white" style="color: var(--blue);">
                {c.category}
              </span>
              <h3 class="font-display font-semibold text-2xl" style="color: #ffffff; line-height: 1.1;">{c.client}</h3>
            </div>
          </div>

          <!-- Bottom Text & Metrics Container -->
          <div class="p-5 lg:p-6 flex flex-col flex-1">
            <p class="font-body text-sm leading-relaxed mb-6 flex-1" style="color: var(--text-dim); line-height: 1.7;">
              {c.result}
            </p>

            <!-- Metrics -->
            <div class="grid grid-cols-3 gap-3 pt-5 border-t" style="border-color: rgba(15,23,42,0.06);">
              {c.metrics.map((m) => (
                <div>
                  <p class="font-display font-semibold text-2xl mb-1 text-blue-600 tracking-tight">{m.value}</p>
                  <p class="font-mono text-[0.5rem] tracking-widest uppercase leading-tight" style="color: var(--text-muted);">{m.label}</p>
                </div>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
