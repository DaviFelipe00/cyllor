---
// Hero: Full-bleed photo, giant display title, elegant tagline — Elyse-inspired
---
<section
  id="hero"
  class="relative min-h-screen flex flex-col overflow-hidden"
>
  <!-- Full-bleed background image -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1920&q=85&auto=format&fit=crop"
      alt="Condomínio residencial moderno iluminado ao entardecer"
      class="w-full h-full object-cover object-center"
      loading="eager"
    />
    <!-- Dark overlay gradient -->
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(11,12,11,0.35) 0%, rgba(11,12,11,0.15) 40%, rgba(11,12,11,0.60) 80%, rgba(11,12,11,0.92) 100%);" />
    <!-- Side vignette -->
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(11,12,11,0.5) 0%, transparent 40%, transparent 60%, rgba(11,12,11,0.4) 100%);" />
  </div>

  <!-- Top divider line -->
  <div class="absolute top-0 left-0 right-0 h-px z-10" style="background: linear-gradient(90deg, transparent, rgba(201,169,110,0.25), transparent);"></div>

  <!-- Content layer -->
  <div class="relative z-10 flex flex-col justify-between min-h-screen px-6 sm:px-10 lg:px-14 pt-28 pb-14">

    <!-- Top row: subtle tagline -->
    <div class="flex items-start justify-end max-w-7xl mx-auto w-full">
      <div class="max-w-xs text-right hidden lg:block" data-reveal="right" data-delay="300">
        <p class="font-mono text-[0.6rem] tracking-[0.28em] uppercase mb-3" style="color: rgba(201,169,110,0.7);">Software para Condomínios</p>
        <div class="h-px w-full mb-3" style="background: rgba(201,169,110,0.2);"></div>
      </div>
    </div>

    <!-- Giant title + right panel -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between max-w-7xl mx-auto w-full gap-8 lg:gap-0">

      <!-- Giant CYLLOR title -->
      <div class="flex-1">
        <h1
          id="hero-title"
          class="font-display font-light leading-[0.85] tracking-tighter select-none"
          style="font-size: clamp(6rem, 20vw, 18rem); color: rgba(240,235,225,0.95); letter-spacing: -0.02em;"
          data-reveal
        >
          CYLLOR
        </h1>
      </div>

      <!-- Right: headline + description -->
      <div class="lg:max-w-[340px] lg:pb-4 lg:pl-8" data-reveal="right" data-delay="200">
        <h2 class="font-display font-light italic text-2xl sm:text-3xl leading-tight mb-5" style="color: var(--cream);">
          Operação inteligente<br/>
          <span class="not-italic font-light" style="color: var(--gold);">em perfeita harmonia</span>
        </h2>
        <p class="font-body text-sm leading-relaxed mb-6" style="color: rgba(240,235,225,0.6);">
          Centralize reservas, comunicados, controle de acesso e rotinas do condomínio. A Cyllor simplifica a gestão e eleva a experiência dos moradores.
        </p>
        <a href="#contact" class="btn-gold" data-cursor-hover>
          Agendar demonstração
        </a>
      </div>
    </div>

    <!-- Bottom: scroll indicator -->
    <div id="hero-scroll-hint" class="flex items-center gap-4 max-w-7xl mx-auto w-full">
      <div class="flex flex-col items-center gap-2">
        <span class="font-mono text-[0.55rem] tracking-[0.3em] uppercase" style="color: rgba(240,235,225,0.4);">SCROLL</span>
        <div class="w-px h-10 animate-float" style="background: linear-gradient(to bottom, rgba(201,169,110,0.5), transparent);"></div>
      </div>
    </div>

  </div>
</section>
