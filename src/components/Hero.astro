---
// Hero: Full-bleed photo, giant display title, elegant tagline
---
<section
  id="hero"
  class="relative min-h-screen flex flex-col overflow-hidden"
>
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1920&q=85&auto=format&fit=crop"
      alt="Condomínio residencial moderno iluminado ao entardecer"
      class="w-full h-full object-cover object-center"
      loading="eager"
    />
    <!-- White elegant overlay gradient, reduced spread to reveal more image -->
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.85) 25%, transparent 65%);" />
    <!-- Bottom fade to solid white to blend with the next section -->
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(255,255,255,0.7) 0%, rgba(255,255,255,0) 20%, rgba(255,255,255,0) 80%, var(--bg) 100%);" />
  </div>

  <!-- Top divider line -->
  <div class="absolute top-0 left-0 right-0 h-px z-10" style="background: linear-gradient(90deg, transparent, rgba(37,99,235,0.15), transparent);"></div>

  <!-- Content layer -->
  <div class="relative z-10 flex flex-col justify-between min-h-screen px-6 sm:px-10 lg:px-14 pt-28 pb-14">

    <!-- Title + subtext stacked -->
    <div class="flex flex-col justify-center items-center sm:items-start max-w-[1500px] w-full flex-1 mt-0 sm:mt-16 lg:ml-0 lg:mr-auto">

      <!-- Main Headline Block -->
      <div class="max-w-[650px] xl:max-w-[800px] w-full flex flex-col items-center sm:items-start" data-reveal="left" data-delay="100">
        
        <h1 class="hidden sm:block font-sans text-lg sm:text-2xl lg:text-[2.2rem] leading-tight font-bold tracking-[0.1em] uppercase text-blue-600 mb-10 mt-12">
          O Novo Padrão em Software para Condomínios.
        </h1>
        
        <!-- Button Group -->
        <div class="flex items-center flex-col sm:flex-row flex-wrap gap-4 w-full sm:w-auto">
          <a href="#contact" class="w-full sm:w-auto inline-flex items-center justify-center bg-blue-600 text-white font-sans text-sm sm:text-base tracking-wide uppercase px-10 py-4 sm:py-5 rounded-full hover:bg-blue-700 hover:-translate-y-0.5 transition-all duration-300 font-bold shadow-lg shadow-blue-500/20" data-cursor-hover>
            Agendar demonstração
          </a>
          <a href="#lifestyle" class="w-full sm:w-auto inline-flex items-center justify-center bg-blue-100 text-blue-700 font-sans text-sm sm:text-base tracking-wide uppercase px-10 py-4 sm:py-5 rounded-full hover:bg-blue-200 hover:-translate-y-0.5 border border-blue-200/50 transition-all duration-300 font-bold" data-cursor-hover>
            Como funciona
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom: scroll indicator -->
    <div id="hero-scroll-hint" class="flex items-center gap-4 max-w-7xl mx-auto w-full">
      <div class="flex flex-col items-center gap-2">
        <span class="font-mono text-[0.55rem] tracking-[0.3em] uppercase text-blue-500">SCROLL</span>
        <div class="w-px h-10 animate-float bg-blue-500/40"></div>
      </div>
    </div>

  </div>
</section>
