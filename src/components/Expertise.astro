---
// Expertise: "Facilidades" — dark cards with gold accents, Elyse mission/values style
const skills = [
  {
    num: '01',
    title: 'Comunicados e avisos',
    desc: 'Envio rápido de avisos, documentos e mensagens para todos os moradores, com histórico organizado. Menos ruído, mais informação.',
    tags: ['Mural', 'Circulares', 'Documentos'],
  },
  {
    num: '02',
    title: 'Reservas de áreas comuns',
    desc: 'Controle de salão, churrasqueira, quadra e espaços compartilhados em um calendário simples. Regras claras eliminam conflitos.',
    tags: ['Calendário', 'Regras', 'Confirmação'],
  },
  {
    num: '03',
    title: 'Controle de acesso',
    desc: 'Visitantes, prestadores e entregas com autorização clara para portaria e registro centralizado. Rastreabilidade em tempo real.',
    tags: ['Visitantes', 'Entregas', 'Portaria'],
  },
  {
    num: '04',
    title: 'Rotina financeira',
    desc: 'Atalhos para boletos, documentos e solicitações frequentes sem depender de tantos canais paralelos.',
    tags: ['Boletos', 'Arquivos', 'Solicitações'],
  },
  {
    num: '05',
    title: 'Experiência do morador',
    desc: 'Uma jornada mais amigável para resolver tarefas do condomínio pelo celular ou navegador, a qualquer hora.',
    tags: ['App web', 'Morador', 'Atendimento'],
  },
  {
    num: '06',
    title: 'Indicadores da operação',
    desc: 'Visão rápida do que está pendente, do que foi resolvido e do que mais gera demanda no condomínio.',
    tags: ['Painel', 'Pendências', 'Acompanhamento'],
  },
];
---
<section id="expertise" class="relative py-24 sm:py-32 overflow-hidden" style="background: var(--dark);">

  <div class="section-divider"></div>

  <div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-14">

    <!-- Header + mission statement -->
    <div class="mb-16 sm:mb-24 grid lg:grid-cols-2 gap-10 lg:gap-16 items-end">
      <div data-reveal>
        <span class="section-label mb-5 block">(Facilidades)</span>
        <h2 class="font-display font-light leading-tight" style="font-size: clamp(2.5rem, 5.5vw, 5rem); color: var(--cream);">
          Uma visão de operação<br/>
          <span class="italic" style="color: var(--gold);">inteligente</span>
        </h2>
      </div>
      <div data-reveal="right" data-delay="100">
        <p class="font-body text-sm sm:text-base leading-relaxed mb-5" style="color: rgba(240,235,225,0.55); line-height: 1.9;">
          Inspirar e sustentar um condomínio mais organizado, em que a gestão, a portaria e os moradores operam com menos atrito e mais clareza.
        </p>
        <div class="h-px" style="background: rgba(201,169,110,0.2);"></div>
      </div>
    </div>

    <!-- Features grid -->
    <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-5">
      {skills.map((skill, i) => (
        <article
          class="group relative p-7 sm:p-9 gold-border rounded-sm flex flex-col gap-5 transition-all duration-500 hover:border-cyllor-gold"
          style="background: var(--surface);"
          data-reveal
          data-delay={i * 80}
          data-cursor-hover
        >
          <!-- Hover glow -->
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none rounded-sm"
            style="background: radial-gradient(circle at 50% 0%, rgba(201,169,110,0.06) 0%, transparent 65%)"></div>

          <!-- Number -->
          <span class="font-mono text-[0.58rem] tracking-[0.28em] uppercase" style="color: rgba(201,169,110,0.45);">{skill.num}</span>

          <!-- Title -->
          <h3 class="font-display font-light text-2xl sm:text-[1.7rem] leading-tight transition-colors duration-300 group-hover:text-cyllor-gold" style="color: var(--cream);">
            {skill.title}
          </h3>

          <!-- Description -->
          <p class="font-body text-sm leading-relaxed flex-1" style="color: rgba(240,235,225,0.5); line-height: 1.8;">
            {skill.desc}
          </p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2 pt-4 border-t" style="border-color: rgba(201,169,110,0.1);">
            {skill.tags.map((tag) => (
              <span class="font-mono text-[0.55rem] px-2.5 py-1 tracking-widest uppercase rounded-full" style="background: rgba(201,169,110,0.07); color: rgba(201,169,110,0.55); border: 1px solid rgba(201,169,110,0.12);">
                {tag}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
