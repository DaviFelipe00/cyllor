---
// Contact: split layout — light theme
const contactState = Astro.url.searchParams.get('contact');
---
<section id="contact" class="relative py-16 lg:py-24 overflow-hidden" style="background: var(--bg-alt);">

  <div class="section-divider"></div>

  <div class="px-6 sm:px-10 lg:px-14 max-w-6xl mx-auto">
    
    <!-- Unified Framed Card -->
    <div class="bg-white rounded-3xl shadow-[0_8px_40px_rgb(0,0,0,0.06)] border border-slate-100 overflow-hidden flex flex-col lg:flex-row relative">
      
      <!-- Decoration Flare behind the form part -->
      <div class="absolute top-0 right-0 w-64 h-64 bg-blue-50/80 rounded-full blur-[60px] pointer-events-none -mr-20 -mt-20"></div>

      <!-- Left: Image -->
      <div class="lg:w-[45%] relative min-h-[250px] sm:min-h-[350px] lg:min-h-full flex flex-col">
        <img
          src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=1200&q=85&auto=format&fit=crop"
          alt="Condomínio residencial sofisticado"
          class="absolute inset-0 w-full h-full object-cover"
        />
        <!-- Overlay Gradient -->
        <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(15,23,42,0.4) 0%, rgba(15,23,42,0.85) 100%);"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 to-transparent lg:hidden"></div>
        
        <div class="relative flex-1 flex items-end p-8 sm:p-12 lg:p-16">
          <div>
            <h2 class="font-display font-semibold text-3xl sm:text-4xl mb-3" style="color: #ffffff;">
              Visualize sua<br/>operação com a Cyllor
            </h2>
            <p class="font-mono text-[0.55rem] tracking-widest uppercase" style="color: rgba(255,255,255,0.7);">
              Fale com um de nossos especialistas
            </p>
          </div>
        </div>
      </div>

      <!-- Right: Form Panel -->
      <div class="lg:w-[55%] flex flex-col justify-center px-8 sm:px-12 lg:px-16 py-14 sm:py-20 lg:py-24 relative z-10 bg-white">
        
        <div class="mb-8 relative z-10">
          <h2 class="font-display font-semibold text-3xl mb-3" style="color: var(--text);">
            Agende uma demonstração
          </h2>
          <p class="font-mono text-[0.55rem] tracking-widest uppercase" style="color: var(--text-muted);">
            Nossa equipe entrará em contato em breve
          </p>
        </div>

      {contactState === 'success' && (
        <div class="mb-8 px-5 py-4 text-sm rounded bg-blue-50 border border-blue-200 text-blue-700">
          Recebemos sua mensagem. Vamos retornar em breve.
        </div>
      )}
      {contactState === 'error' && (
        <div class="mb-8 px-5 py-4 text-sm rounded bg-red-50 border border-red-200 text-red-700">
          Não foi possível enviar. Revise os campos e tente novamente.
        </div>
      )}

      <form action="/api/contact" method="POST" class="flex flex-col gap-6 w-full relative z-10">

        <div class="flex flex-col gap-1.5">
          <label class="elyse-label" for="c-name">Nome</label>
          <input id="c-name" name="name" required class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-800 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all font-body placeholder:text-slate-400" placeholder="Seu nome completo" />
        </div>

        <div class="flex flex-col gap-1.5">
          <label class="elyse-label" for="c-email">E-mail</label>
          <input id="c-email" name="email" type="email" required class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-800 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all font-body placeholder:text-slate-400" placeholder="voce@empresa.com" />
        </div>

        <div class="flex flex-col gap-1.5">
          <label class="elyse-label" for="c-company">Condomínio ou empresa</label>
          <input id="c-company" name="company" required class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-800 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all font-body placeholder:text-slate-400" placeholder="Nome do condomínio ou administradora" />
          <input type="hidden" name="interest" value="Solicitação de demonstração" />
        </div>

        <div class="flex flex-col gap-1.5">
          <label class="elyse-label" for="c-challenge">Mensagem</label>
          <textarea
            id="c-challenge"
            name="challenge"
            required
            rows="3"
            class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-800 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all font-body placeholder:text-slate-400 resize-none"
            placeholder="Descreva o principal gargalo da operação atual"
          ></textarea>
        </div>

        <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

        <div class="flex flex-col gap-3 mt-2">
          <button
            type="submit"
            class="btn-gold-fill w-full justify-center"
            data-cursor-hover
          >
            Agendar demonstração
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M2 8h12M10 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <p class="font-mono text-[0.55rem] tracking-widest text-center leading-relaxed" style="color: var(--text-muted);">
            Ao enviar, você concorda com nossa política de privacidade.<br/>Seus dados são usados apenas para retorno comercial.
          </p>
        </div>
      </form>
      </div>
    </div>
  </div>
</section>

<script>
  const contactForm = document.querySelector('#contact form');

  if (contactForm) {
    const validationMessages = {
      name: 'Informe seu nome.',
      emailRequired: 'Informe seu e-mail.',
      emailInvalid: 'Informe um e-mail valido.',
      company: 'Informe o nome do condominio ou da empresa.',
      challenge: 'Escreva sua mensagem.',
    };

    const getMessage = (field) => {
      if (!(field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement)) return '';

      if (field.name === 'email') {
        if (field.validity.valueMissing) return validationMessages.emailRequired;
        if (field.validity.typeMismatch) return validationMessages.emailInvalid;
      }

      if (field.name === 'name' && field.validity.valueMissing) return validationMessages.name;
      if (field.name === 'company' && field.validity.valueMissing) return validationMessages.company;
      if (field.name === 'challenge' && field.validity.valueMissing) return validationMessages.challenge;

      return '';
    };

    contactForm.querySelectorAll('input, textarea').forEach((field) => {
      field.addEventListener('invalid', () => {
        field.setCustomValidity(getMessage(field));
      });

      field.addEventListener('input', () => {
        field.setCustomValidity('');
      });
    });
  }
</script>
