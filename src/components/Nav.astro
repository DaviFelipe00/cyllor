---
const links = [
  { label: 'Como funciona', href: '#lifestyle' },
  { label: 'Facilidades',   href: '#expertise' },
  { label: 'Resultados',    href: '#cases' },
];
---
<nav
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 px-6 sm:px-8 lg:px-14 py-5 transition-all duration-500"
  style="background: transparent;"
>
  <div class="max-w-7xl mx-auto flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="group flex items-center gap-2" data-cursor-hover>
      <span class="nav-logo font-display font-semibold text-xl sm:text-2xl tracking-[0.18em] transition-colors duration-300">
        CYLLOR
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-10">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            data-cursor-hover
            class="nav-link relative font-mono text-[0.6rem] tracking-[0.22em] uppercase transition-colors duration-300 group"
          >
            {link.label}
            <span class="absolute -bottom-1 left-0 h-px w-0 bg-blue-500 transition-all duration-400 group-hover:w-full" />
          </a>
        </li>
      ))}
    </ul>

    <a
      href="#contact"
      class="btn-gold hidden md:inline-flex"
      data-cursor-hover
      style="color: #ffffff; border-color: rgba(255,255,255,0.5);"
      id="nav-cta"
    >
      Agendar demo
    </a>

    <!-- Mobile hamburger -->
    <button
      id="nav-toggle"
      aria-label="Abrir menu"
      aria-expanded="false"
      aria-controls="nav-drawer"
      class="nav-hamburger md:hidden flex flex-col gap-[6px] p-2 -mr-2"
    >
      <span class="nav-bar block w-6 h-px bg-current transition-all duration-300"></span>
      <span class="nav-bar block w-4 h-px bg-blue-500 transition-all duration-300"></span>
      <span class="nav-bar block w-6 h-px bg-current transition-all duration-300"></span>
    </button>
  </div>
</nav>

<!-- Mobile Drawer -->
<div
  id="nav-drawer"
  class="fixed inset-0 z-40 flex flex-col justify-center items-center gap-10 translate-x-full transition-transform duration-500 ease-in-out md:hidden"
  style="background: rgba(255,255,255,0.97); backdrop-filter: blur(20px);"
  aria-hidden="true"
>
  {links.map((link) => (
    <a
      href={link.href}
      data-nav-link
      class="font-display font-semibold text-4xl hover:text-blue-600 transition-colors duration-300 tracking-wider"
      style="color: #0f172a;"
    >
      {link.label}
    </a>
  ))}
  <a
    href="#contact"
    data-nav-link
    class="btn-gold mt-4"
  >
    Agendar demo
  </a>
</div>

<script>
  const toggle   = document.getElementById('nav-toggle');
  const drawer   = document.getElementById('nav-drawer');
  const navLinks = Array.from(document.querySelectorAll('[data-nav-link]'));
  const bars     = Array.from(document.querySelectorAll('.nav-bar'));
  const navCta   = document.getElementById('nav-cta');
  let open = false;

  function setOpen(state: boolean) {
    if (!toggle || !drawer) return;
    open = state;
    drawer.style.transform = open ? 'translateX(0)' : 'translateX(100%)';
    drawer.setAttribute('aria-hidden', open ? 'false' : 'true');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    document.body.style.overflow = open ? 'hidden' : '';
    bars[0].style.transform = open ? 'translateY(7px) rotate(45deg)'  : '';
    bars[1].style.opacity   = open ? '0' : '1';
    bars[2].style.transform = open ? 'translateY(-7px) rotate(-45deg)' : '';
    if (open) navLinks[0]?.focus();
    else toggle.focus();
  }

  toggle?.addEventListener('click', () => setOpen(!open));
  navLinks.forEach(l => l.addEventListener('click', () => setOpen(false)));

  // Update CTA style on scroll
  const siteNav = document.getElementById('site-nav');
  window.addEventListener('scroll', () => {
    if (navCta) {
      if (window.scrollY > 60) {
        navCta.style.color = '';
        navCta.style.borderColor = '';
      } else {
        navCta.style.color = '#ffffff';
        navCta.style.borderColor = 'rgba(255,255,255,0.5)';
      }
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && open) setOpen(false);
  });
</script>
